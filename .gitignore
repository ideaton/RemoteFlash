# ─── RemoteFlash — .gitignore ──────────────────────────────────────
# Règle : on ne pousse que le code source et les scripts de build.
# Tout ce qui est généré, lourd ou sensible reste local.

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ── Build (PyInstaller / Inno Setup) — fichiers générés, lourds ──
build/dist/
build/work/
build/Output/
*.spec
*.exe

# ── SENSIBLE — ne jamais committer ──
# Clés SSH / certificats
*.pem
*.ppk
*.key
id_rsa*
id_ecdsa*
id_ed25519*
known_hosts

# Secrets / configs locales (contiennent IP, users, mots de passe)
.env
.env.*
*.secret
.ssh_flasher_pro.json
ports-label.json
config.local.*

# Firmwares de prod (au cas où)
*.hex
*.bin
firmware_backup*

# ── OS / IDE ──
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
